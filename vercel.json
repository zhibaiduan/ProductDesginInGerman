{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/germany_digital_product_handbook.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/germany_pretest_v4.html",
      "destination": "/pretest",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
